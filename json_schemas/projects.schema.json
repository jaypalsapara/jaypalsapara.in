{
  "$schema": "https://json-schema.org/draft/2020-12/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "name", "type", "term", "thumbnail", "under_nda"],
    "properties": {
      "id": {
        "type": "string"
      },
      "name": {
        "type": "string"
      },
      "type": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": ["website", "mobile_app", "desktop_app"]
        }
      },
      "term": {
        "type": "string",
        "enum": ["case_study", "recent", "personal"]
      },
      "thumbnail": {
        "type": "string"
      },
      "under_nda": {
        "type": "boolean"
      }
    },
    "additionalProperties": false
  }
}
